# Claude API key for AI summaries: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# transcriptapi.com key (primary transcript provider on production)
TRANSCRIPT_API_KEY=sk_...

# Upstash Redis / Vercel KV for cross-instance rate limiting (optional).
# Without these the limiter falls back to a per-instance in-memory counter.
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...
